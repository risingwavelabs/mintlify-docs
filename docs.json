{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Wavelet",
  "colors": {
    "primary": "#005eec",
    "light": "#3B82F6",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/overview"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "overview",
              "getting-started",
              "config"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/client",
              "sdk/react"
            ]
          },
          {
            "group": "Server",
            "pages": [
              "server/http-api",
              "server/websocket",
              "server/jwt-auth"
            ]
          },
          {
            "group": "Data Sources",
            "pages": [
              "sources/postgres-cdc"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "codegen",
              "mcp"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/risingwavelabs/wavelet",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/@risingwave/wavelet",
          "icon": "npm"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "RisingWave",
        "href": "https://risingwave.com"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/risingwavelabs/wavelet",
      "x": "https://x.com/risingaborwave"
    }
  }
}
